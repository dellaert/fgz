fgz 1
theme classic

x1 = x_1
x2 = x_2
x3 = x_3
l1 = l_1
l2 = l_2

variable x1 (0, 0)
variable x2 (2, 0)
variable x3 (4.5, 0)
node l1 {x1, x2} (2, 2)
node l2 {x3} (4.5, 2)

factor {x1} (-1, 0)
factor {x1} (0, -1)
factor {x1, x2}
factor {x2} (1.1, -0.45)
factor {x3} (3.3, 0)
factor {x3} (4.5, -1)

curve x1 -- x2 via (1, -0.5)
