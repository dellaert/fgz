    "examples:svg": "npm run build && node scripts/build-examples.mjs --svg-only"
  },
  "dependencies": {
    "node-tikzjax": "^1.0.5"
  },
  "devDependencies": {
    "@types/node": "^20.17.57",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
