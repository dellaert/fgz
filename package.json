{
  "name": "fgz",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "fgz2tex": "./packages/fgz-cli/bin/fgz2tex",
    "fgz2svg": "./packages/fgz-cli/bin/fgz2svg"
  },
  "scripts": {
    "build": "tsc -b",
    "test": "vitest run",
